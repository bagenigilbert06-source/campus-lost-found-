# Database Configuration - REQUIRED
# MongoDB Atlas (Cloud)
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/campus-lost-found

# Firebase Admin SDK Configuration - REQUIRED
# Get service account key from: Firebase Console → Project Settings → Service Accounts
# Download as JSON, then fill in the values below
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Frontend URL - REQUIRED FOR PRODUCTION
# This should be your deployed frontend domain
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Optional (frontend app can use this via VITE_API_URL)
# VITE_API_URL=https://your-backend-domain.com/api

# Server Configuration
PORT=3001
NODE_ENV=production

# Google Gemini Configuration (AI Features) - REQUIRED
# Get your API key from: https://aistudio.google.com/app/apikey
# IMPORTANT: Never commit real API keys to version control
GEMINI_API_KEY=your-new-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT=30000
GEMINI_MAX_TOKENS=500

# Email Configuration (Optional)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password

# Development Only
LOG_LEVEL=info
