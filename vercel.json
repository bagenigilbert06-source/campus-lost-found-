{
  "version": 2,
  "installCommand": "pnpm install && cd backend && pnpm install && cd ..",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/[...all].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].ts"
    },
    {
      "src": "^/(assets/.*|favicon\\.ico|robots\\.txt|sitemap\\.xml)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
