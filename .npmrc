# pnpm configuration for Campus Lost & Found

# Use strict peer dependency handling
strict-peer-dependencies=false

# Auto-install peer dependencies
auto-install-peers=true

# Use linked installs for faster workspace installs
shamefully-hoist=false

# Enable store for better performance
store-dir=.pnpm-store

# Use lock file v5 for better performance
lockfile-include-tarball-url=true

# Prefer offline mode if packages are cached
prefer-offline=false

# Node modules directory
node-modules-dir=node_modules
